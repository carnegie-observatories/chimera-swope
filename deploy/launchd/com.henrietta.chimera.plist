<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.henrietta.chimera</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/Shared/henrietta/bin/chimera-launch.sh</string>
    </array>

    <key>UserName</key>
    <string>henrietta</string>

    <key>WorkingDirectory</key>
    <string>/Users/henrietta</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>/Users/henrietta</string>
        <key>PATH</key>
        <string>/Users/henrietta/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>LANG</key>
        <string>en_US.UTF-8</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>Crashed</key>
        <true/>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>/Users/Shared/henrietta/logs/chimera.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/Shared/henrietta/logs/chimera.err.log</string>
</dict>
</plist>
